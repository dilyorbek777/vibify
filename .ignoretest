            >
              <div className="h-1.5 w-full bg-white/15" />
            </div>
          ))}
        </div>

        <div
          className={`absolute z-30 rounded-md overflow-hidden transition-all duration-500 ease-out ${
            hoveredTileData ? 'opacity-100 scale-100' : 'opacity-0 scale-95 pointer-events-none'
          }`}
          style={{
            top: '50%',
            left: '50%',
            width: 220,
            height: 280,
            transform: 'translate(-50%, -50%)',
            boxShadow: hoveredTileData
              ? `0 0 0 1px ${hoveredTileData.color}80, 0 25px 60px rgba(0,0,0,0.7), 0 0 40px ${hoveredTileData.color}40`
              : '0 20px 45px rgba(0,0,0,0.6)',
            background: hoveredTileData
              ? `linear-gradient(200deg, ${hoveredTileData.color} 0%, #24365E 60%, #1c1c1c 100%)`
              : 'linear-gradient(200deg, #C4392B 0%, #24365E 60%, #1c1c1c 100%)',
          }}
        >
          <div className="absolute inset-0 bg-gradient-to-t from-black/85 via-black/10 to-black/40" />
          {hoveredTileData && (
            <div className="absolute inset-x-0 bottom-0 p-4">
              <div className="flex items-center gap-2 mb-3">
                <div
                  className="w-6 h-6 rounded-sm"
                  style={{ backgroundColor: hoveredTileData.color }}
                />
                <p className={`${bebas.className} text-white text-2xl leading-tight tracking-wide`}>
                  TILE #{hoveredTileData.id}
                </p>
              </div>
              <p className={`${inter.className} text-xs text-white/80 mb-1`}>
                <span className="text-white/50">Latitude:</span> {hoveredTileData.lat.toFixed(1)}°
              </p>
              <p className={`${inter.className} text-xs text-white/80 mb-1`}>
                <span className="text-white/50">Longitude:</span> {hoveredTileData.lon.toFixed(1)}°
              </p>
              <p className={`${inter.className} text-xs text-white/80 mb-1`}>
                <span className="text-white/50">Brightness:</span> {(hoveredTileData.shade * 100).toFixed(0)}%
              </p>
              <p className={`${inter.className} text-[10px] text-white/50 mt-2`}>
                Color: {hoveredTileData.color}
              </p>
            </div>
          )}
          <div className="absolute inset-0 ring-1 ring-white/10 rounded-md pointer-events-none" />
        </div>

      </div> */}
        </main>
    );
}