'use client';

import { useEffect, useMemo, useState } from 'react';
import { Bebas_Neue, Inter } from 'next/font/google';

const bebas = Bebas_Neue({ subsets: ['latin'], weight: '400' });
const inter = Inter({ subsets: ['latin'], weight: ['400', '500', '600'] });

// ---- deterministic PRNG so server and client render identical output ----
function mulberry32(seed: number) {
    let t = seed;
    return function () {
        t += 0x6d2b79f5;
        let r = Math.imul(t ^ (t >>> 15), t | 1);
        r ^= r + Math.imul(r ^ (r >>> 7), r | 61);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
    };
}

const PALETTE = [
    '#C4392B', // marquee red
    '#E8B84B', // ticket gold
    '#2E6E62', // reel teal
    '#24365E', // midnight navy
    '#D8CBB0', // paper cream
    '#7A3E65', // plum
    '#B8722E', // amber
    '#1C1C1C', // near black
];

interface SphereTile {
    lat: number;
    lon: number;
    color: string;
    shade: number;
    id: number;
}

interface FlatTile {
    color: string;
    opacity: number;
    id: number;
}

const ROWS = 15;
const COLS = 26;
const RADIUS = 220;
const TILE_W = 32;
const TILE_H = 46;

const BG_COLS = 16;
const BG_ROWS = 10;

export default function HoverAnimPage() {
    const [hovered, setHovered] = useState(false);
    const [hoveredTile, setHoveredTile] = useState<number | null>(null);
    const [hoveredBgTile, setHoveredBgTile] = useState<number | null>(null);
    const [reducedMotion, setReducedMotion] = useState(false);
    const [cursorPosition, setCursorPosition] = useState({ x: 0, y: 0 });

    useEffect(() => {
        const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
        setReducedMotion(mq.matches);
        const handler = (e: MediaQueryListEvent) => setReducedMotion(e.matches);
        mq.addEventListener('change', handler);
        return () => mq.removeEventListener('change', handler);
    }, []);

    const sphereTiles = useMemo<SphereTile[]>(() => {
        const rand = mulberry32(42);
        const tiles: SphereTile[] = [];
        let id = 0;
        for (let r = 0; r < ROWS; r++) {
            const lat = -78 + (156 * r) / (ROWS - 1);
            const lonOffset = r % 2 === 0 ? 0 : 360 / COLS / 2;
            for (let c = 0; c < COLS; c++) {
                const lon = (360 / COLS) * c + lonOffset;
                tiles.push({
                    id: id++,
                    lat,
                    lon,
                    color: PALETTE[Math.floor(rand() * PALETTE.length)],
                    shade: 0.55 + rand() * 0.45,
                });
            }
        }
        return tiles;
    }, []);

    const hoveredTileData = useMemo(() => {
        if (hoveredTile === null) return null;
        return sphereTiles.find((t) => t.id === hoveredTile);
    }, [hoveredTile, sphereTiles]);

    const flatTiles = useMemo<FlatTile[]>(() => {
        const rand = mulberry32(7);
        const count = BG_COLS * BG_ROWS;
        const tiles: FlatTile[] = [];
        for (let i = 0; i < count; i++) {
            tiles.push({
                id: i,
                color: PALETTE[Math.floor(rand() * PALETTE.length)],
                opacity: 0.18 + rand() * 0.4,
            });
        }
        return tiles;
    }, []);

    const hoveredBgTileData = useMemo(() => {
        if (hoveredBgTile === null) return null;
        return flatTiles.find((t) => t.id === hoveredBgTile);
    }, [hoveredBgTile, flatTiles]);


    return (
        <main 
            className="relative min-h-screen w-full overflow-hidden bg-[#050507] flex items-center justify-center"
            onMouseMove={(e) => setCursorPosition({ x: e.clientX, y: e.clientY })}
        >
            <style>{`
        @keyframes spin-sphere {
          from { transform: rotateY(0deg); }
          to { transform: rotateY(360deg); }
        }
      `}</style>

            {/* full-bleed mosaic backdrop */}
            <div
                className="absolute inset-0 grid"
                style={{ gridTemplateColumns: `repeat(${BG_COLS}, 1fr)` }}
            >
                {flatTiles.map((t, i) => (
                    <div
                        key={i}
                        style={{
                            backgroundColor: t.color,
                            opacity: hoveredBgTile === t.id ? 1 : t.opacity,
                            transform: hoveredBgTile === t.id ? 'scale(1.1)' : 'scale(1)',
                            boxShadow: hoveredBgTile === t.id ? `0 0 20px ${t.color}, 0 0 40px rgba(0,0,0,0.8)` : 'none',
                            zIndex: hoveredBgTile === t.id ? 100 : 1,
                        }}
                        className="aspect-[2/3] cursor-pointer transition-all duration-300 rounded-sm"
                        onMouseEnter={() => setHoveredBgTile(t.id)}
                        onMouseLeave={() => setHoveredBgTile(null)}
                    />
                ))}
            </div>

            {/* vignette */}
            {/* <div
        className="absolute inset-0 pointer-events-none"
        style={{
          background:
            'radial-gradient(ellipse at center, rgba(5,5,7,0.35) 0%, rgba(5,5,7,0.75) 55%, rgba(5,5,7,0.97) 100%)',
        }}
        aria-hidden
      /> */}

            {/* info card for background tiles */}
            {hoveredBgTileData && (
                <div
                    className="absolute z-30 rounded-md overflow-hidden transition-all duration-300 ease-out pointer-events-none"
                    style={{
                        top: cursorPosition.y + 20,
                        left: cursorPosition.x + 20,
                        width: 200,
                        height: 240,
                        boxShadow: `0 0 0 1px ${hoveredBgTileData.color}80, 0 25px 60px rgba(0,0,0,0.7), 0 0 40px ${hoveredBgTileData.color}40`,
                        background: `linear-gradient(200deg, ${hoveredBgTileData.color} 0%, #24365E 60%, #1c1c1c 100%)`,
                    }}
                >
                    <div className="absolute inset-0 bg-gradient-to-t from-black/85 via-black/10 to-black/40" />
                    <div className="absolute inset-x-0 bottom-0 p-4">
                        <div className="flex items-center gap-2 mb-3">
                            <div
                                className="w-6 h-6 rounded-sm"
                                style={{ backgroundColor: hoveredBgTileData.color }}
                            />
                            <p className={`${bebas.className} text-white text-2xl leading-tight tracking-wide`}>
                                TILE #{hoveredBgTileData.id}
                            </p>
                        </div>
                        <p className={`${inter.className} text-xs text-white/80 mb-1`}>
                            <span className="text-white/50">Opacity:</span> {(hoveredBgTileData.opacity * 100).toFixed(0)}%
                        </p>
                        <p className={`${inter.className} text-[10px] text-white/50 mt-2`}>
                            Color: {hoveredBgTileData.color}
                        </p>
                    </div>
                    <div className="absolute inset-0 ring-1 ring-white/10 rounded-md pointer-events-none" />
                </div>
            )}


            {/* full-page interactive tile grid */}
            {/* <div
        className="relative z-10 w-full h-full"
        onMouseEnter={() => setHovered(true)}
        onMouseLeave={() => setHovered(false)}
      >
        <div
          className="absolute inset-0 grid grid-cols-10 items-center justify-center gap-10"
       
        >
          {sphereTiles.map((t, i) => (
            <div
              key={i}
              className="rounded-[2px] overflow-hidden cursor-pointer transition-all duration-300"
              style={{
                aspectRatio: `${TILE_W}/${TILE_H}`,
                background: `linear-gradient(160deg, ${t.color}, rgba(0,0,0,0.6))`,
                opacity: hoveredTile === t.id ? 1 : t.shade,
                transform: hoveredTile === t.id ? 'scale(1.08)' : 'scale(1)',
                boxShadow: hoveredTile === t.id ? `0 0 15px ${t.color}, 0 0 30px rgba(0,0,0,0.8)` : '0 0 4px rgba(0,0,0,0.3)',
                zIndex: hoveredTile === t.id ? 100 : 1,
              }}
